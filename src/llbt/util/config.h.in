// Version information
#cmakedefine LLBT_VERSION "@VERSION@"

// Feature detection
#cmakedefine01 LLBT_HAVE_READDIR64
#cmakedefine01 LLBT_HAVE_POSIX_FALLOCATE
#cmakedefine01 LLBT_USE_SYSTEM_OPENSSL_PATHS
#cmakedefine01 LLBT_HAVE_OPENSSL
#cmakedefine01 LLBT_HAVE_SECURE_TRANSPORT
#cmakedefine01 LLBT_HAVE_PTHREAD_GETNAME
#cmakedefine01 LLBT_HAVE_PTHREAD_SETNAME
#cmakedefine01 LLBT_HAVE_BACKTRACE
#cmakedefine01 LLBT_INCLUDE_CERTS
#define LLBT_MAX_BPNODE_SIZE @LLBT_MAX_BPNODE_SIZE@
#define LLBT_BACKTRACE_HEADER <@Backtrace_HEADER@>
#cmakedefine01 LLBT_ENABLE_ASSERTIONS
#cmakedefine01 LLBT_ENABLE_ALLOC_SET_ZERO
#cmakedefine01 LLBT_ENABLE_ENCRYPTION
#cmakedefine01 LLBT_ENABLE_MEMDEBUG
#cmakedefine01 LLBT_ENABLE_GEOSPATIAL
#cmakedefine01 LLBT_VALGRIND
#cmakedefine01 LLBT_ASAN
#cmakedefine01 LLBT_TSAN
